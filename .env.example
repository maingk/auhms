# =============================================================================
# AUHMS Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real credentials.
# All secrets are managed via environment variables — no hardcoded values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Supabase PostgreSQL
# Get these from: Supabase project > Settings > Database > Connection string
# Use the "Transaction" pooler URL for DATABASE_URL (PgBouncer-compatible)
# Use the "Direct" connection URL for DIRECT_URL (required for migrations)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`
# NEXTAUTH_URL: set to your deployment URL in production
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Azure Active Directory (Microsoft Entra ID) — SSO
# Register an app in Entra ID and fill in the values below.
# Redirect URI to register: {NEXTAUTH_URL}/api/auth/callback/azure-ad
# Get these from: Azure Portal > App registrations > [your app]
# -----------------------------------------------------------------------------
AZURE_AD_CLIENT_ID="your-azure-ad-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-ad-client-secret"
AZURE_AD_TENANT_ID="your-azure-ad-tenant-id"

# -----------------------------------------------------------------------------
# Microsoft Graph API — Email, Teams, SharePoint
# Use the same App Registration as Azure AD SSO, with additional Graph scopes:
#   Mail.Send, ChannelMessage.Send, Sites.ReadWrite.All
# -----------------------------------------------------------------------------
GRAPH_CLIENT_ID="your-graph-client-id"
GRAPH_CLIENT_SECRET="your-graph-client-secret"
GRAPH_TENANT_ID="your-graph-tenant-id"

# SharePoint site URL where lease documents and inspection forms are stored
SHAREPOINT_SITE_URL="https://averett.sharepoint.com/sites/housing"

# Teams channel webhook URL for staff notifications (or use Power Automate)
TEAMS_WEBHOOK_URL="https://averett.webhook.office.com/webhookb2/..."

# -----------------------------------------------------------------------------
# Application settings
# -----------------------------------------------------------------------------
# Set to "production" | "staging" | "development"
# NEVER use production student data in development or staging environments.
NODE_ENV="development"
